# ========================================
# METRIX GAMING PLATFORM - ENVIRONMENT VARIABLES
# ========================================

# ----------------------------------------
# SUPABASE CONFIGURATION (REQUIRED)
# ----------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ----------------------------------------
# ALATPAY PAYMENT GATEWAY (REQUIRED)
# ----------------------------------------
# Nigerian payment gateway for tournament entry fees
NEXT_PUBLIC_ALATPAY_PUBLIC_KEY=f957181adde8484b973b7efa933f6ef6
NEXT_PUBLIC_ALATPAY_SECRET_KEY=7407371012444541b57febecc0de585e
NEXT_PUBLIC_ALATPAY_BUSINESS_ID=b019677e-cc27-436a-9bda-08dde19160cb

# ----------------------------------------
# OPTIONAL CONFIGURATION
# ----------------------------------------
# Site URL (for production deployment)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# ========================================
# SETUP INSTRUCTIONS
# ========================================
#
# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
#
# 2. Update Supabase credentials:
#    - Go to https://supabase.com/dashboard
#    - Select your project
#    - Go to Settings > API
#    - Copy Project URL and anon public key
#
# 3. AlatPay credentials are pre-filled
#    (Update if you have your own AlatPay account)
#
# 4. Update NEXT_PUBLIC_SITE_URL with your deployment URL
#
# ========================================