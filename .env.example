# Metrix Gaming Platform - Environment Configuration
# Copy this file to .env and update the values for your environment

# =================================================================
# APPLICATION CONFIGURATION
# =================================================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# =================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres123
DB_NAME=metrix
DB_TEST_NAME=metrix_test
DB_SSL=false
DB_CONNECTION_LIMIT=10
DB_LOGGING=true

# =================================================================
# REDIS CONFIGURATION
# =================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# =================================================================
# JWT CONFIGURATION
# =================================================================
# Generate strong random strings for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# =================================================================
# EMAIL CONFIGURATION
# =================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@metrix.com
EMAIL_FROM_NAME=Metrix Platform

# =================================================================
# PAYSTACK PAYMENT CONFIGURATION
# =================================================================
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# =================================================================
# FRONTEND CONFIGURATION
# =================================================================
FRONTEND_URL=http://localhost:3000

# =================================================================
# FILE UPLOAD CONFIGURATION
# =================================================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif

# =================================================================
# SECURITY CONFIGURATION
# =================================================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================================================================
# LOGGING CONFIGURATION
# =================================================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# =================================================================
# SOCKET.IO CONFIGURATION
# =================================================================
SOCKET_CORS_ORIGIN=http://localhost:3000

# =================================================================
# ADMIN CONFIGURATION
# =================================================================
ADMIN_EMAIL=admin@metrix.com
ADMIN_PASSWORD=change-this-secure-password

# =================================================================
# DOCKER CONFIGURATION
# =================================================================
# PostgreSQL Docker Configuration
DB_TEST_PORT=5433

# pgAdmin Docker Configuration
PGADMIN_EMAIL=admin@metrix.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# Redis Commander Configuration
REDIS_COMMANDER_PASSWORD=admin123
REDIS_COMMANDER_PORT=8081

# =================================================================
# BACKUP CONFIGURATION
# =================================================================
BACKUP_RETENTION_DAYS=7

# =================================================================
# WEBHOOK CONFIGURATION
# =================================================================
# Optional: Slack/Discord webhook for notifications
WEBHOOK_URL=

# =================================================================
# DEVELOPMENT/TESTING CONFIGURATION
# =================================================================
# Set to true to enable development features
ENABLE_CORS_ALL_ORIGINS=true
ENABLE_GRAPHQL_PLAYGROUND=true

# =================================================================
# SSL/TLS CONFIGURATION
# =================================================================
# For production deployments
DB_SSL_CA=
DB_SSL_KEY=
DB_SSL_CERT=

# =================================================================
# MONITORING CONFIGURATION
# =================================================================
# Optional: Application monitoring
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# =================================================================
# SOCIAL AUTH CONFIGURATION (Future Implementation)
# =================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# =================================================================
# GAMING PLATFORM INTEGRATIONS (Future Implementation)
# =================================================================
STEAM_API_KEY=
RIOT_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# =================================================================
# NOTIFICATION SERVICES (Future Implementation)
# =================================================================
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Firebase for push notifications
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# =================================================================
# CONTENT DELIVERY NETWORK
# =================================================================
# For file uploads and static assets
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Cloudinary (Alternative CDN)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AlatPay Configuration
NEXT_PUBLIC_ALATPAY_PUBLIC_KEY=f957181adde8484b973b7efa933f6ef6
NEXT_PUBLIC_ALATPAY_SECRET_KEY=7407371012444541b57febecc0de585e
NEXT_PUBLIC_ALATPAY_BUSINESS_ID=582418f7-032f-48ca-27c8-08dcd31fac98

# Add subscription key if you have one
NEXT_PUBLIC_ALATPAY_SUBSCRIPTION_KEY=your_subscription_key_here